// Schema for MyPOS - Multi-tenant SaaS for Laptop & Phone Shop Management
// Modules: Sales (POS), Repair/Service, Inventory, Customers, Users
// Multi-tenant: each Shop is a tenant. All business data is scoped by shopId.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// SHOP (TENANT)
// ============================================
model Shop {
  id           String   @id @default(cuid())
  subdomain    String   @unique // lowercase slug used for routing (e.g. "shop-abc")
  name         String
  ownerEmail   String?
  status       String   @default("active") // active | trial | suspended | deleted
  trialEndsAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users          User[]
  customers      Customer[]
  categories     Category[]
  products       Product[]
  sales          Sale[]
  serviceTickets ServiceTicket[]
  stockMovements StockMovement[]
  notifications  Notification[]
  setting        AppSetting?
}

// ============================================
// SETTINGS / APP CONFIG (per-shop)
// ============================================
model AppSetting {
  shopId      String   @id
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopName    String   @default("MyPOS")
  siteTitle   String   @default("MyPOS - Quản lý cửa hàng")
  shopTagline String   @default("Laptop & Điện thoại")
  shopAddress String?
  shopPhone   String?
  shopEmail   String?
  logoUrl     String?
  faviconUrl  String?
  printSize   String   @default("A4") // A4 | 80mm

  // ----- Print template customization (per-shop) -----
  // Sales / invoice
  saleHeaderNote      String?  // optional extra line under shop info on sale receipt header
  saleFooterNote      String?  // bottom thank-you / message; default "Cảm ơn quý khách! Hẹn gặp lại."
  saleShowSignature   Boolean  @default(true)  // show buyer/seller signature blocks (A4 only)
  saleShowUnitPrice   Boolean  @default(true)  // show unit-price column on thermal too

  // Service intake (phiếu nhận máy)
  intakeHeaderNote String?
  intakeTerms      String?   // bullet list-style terms at bottom (one per line)
  intakeFooterNote String?
  intakeShowSignature Boolean @default(true)

  // Service return (phiếu trả máy)
  returnHeaderNote String?
  returnTerms      String?
  returnFooterNote String?
  returnShowSignature Boolean @default(true)
  // Warranty period to show on return receipt (e.g. "Bảo hành dịch vụ 30 ngày").
  returnWarrantyNote String?

  updatedAt   DateTime @updatedAt
}

// ============================================
// USERS / AUTH
// ============================================
// shopId is nullable so we can have a global superadmin (SaaS owner) with no shop.
// For shop members (admin/staff/technician), shopId is required (enforced at app level).
model User {
  id        String   @id @default(cuid())
  shopId    String?
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  email     String   @unique
  name      String
  password  String
  role      String   @default("staff") // superadmin | admin | staff | technician
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales           Sale[]
  serviceTickets  ServiceTicket[] @relation("CreatedBy")
  serviceAssigned ServiceTicket[] @relation("AssignedTo")
  stockMovements  StockMovement[]
  notifications   Notification[]

  @@index([shopId])
}

// ============================================
// NOTIFICATIONS (real-time alerts)
// ============================================
model Notification {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId    String   // recipient
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // ticket_assigned | ticket_status | low_stock | other
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([shopId, userId, read, createdAt])
}

// ============================================
// CUSTOMERS
// ============================================
model Customer {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  code      String   // KH001 — unique within shop
  name      String
  phone     String   // unique within shop
  email     String?
  address   String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales          Sale[]
  serviceTickets ServiceTicket[]

  @@unique([shopId, code])
  @@unique([shopId, phone])
  @@index([shopId])
}

// ============================================
// CATEGORIES & PRODUCTS
// ============================================
model Category {
  id       String    @id @default(cuid())
  shopId   String
  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name     String
  slug     String
  type     String // laptop | phone | accessory | service
  products Product[]

  @@unique([shopId, slug])
  @@index([shopId])
}

model Product {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sku         String
  name        String
  brand       String?
  description String?
  imageUrl    String?
  price       Float    @default(0)
  costPrice   Float    @default(0)
  stock       Int      @default(0)
  warranty    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  saleItems    SaleItem[]
  serviceItems ServiceItem[]
  movements    StockMovement[]

  @@unique([shopId, sku])
  @@index([shopId])
}

// ============================================
// STOCK MOVEMENTS (Nhập / Xuất / Kiểm kho)
// ============================================
model StockMovement {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  type      String   // in | out | adjust
  quantity  Int
  before    Int
  after     Int
  unitCost  Float    @default(0)
  reason    String?
  reference String?
  createdAt DateTime @default(now())

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([shopId, productId, createdAt])
}

// ============================================
// SALES (POS)
// ============================================
model Sale {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  code          String   // HD20240001 — unique within shop
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  tax           Float    @default(0)
  total         Float    @default(0)
  paid          Float    @default(0)
  paymentMethod String   @default("cash")
  status        String   @default("paid")
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items SaleItem[]

  @@unique([shopId, code])
  @@index([shopId, createdAt])
}

model SaleItem {
  id        String  @id @default(cuid())
  quantity  Int     @default(1)
  unitPrice Float
  discount  Float   @default(0)
  subtotal  Float
  imei      String?
  note      String?

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// ============================================
// SERVICE / REPAIR
// ============================================
model ServiceTicket {
  id            String    @id @default(cuid())
  shopId        String
  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  code          String    // SC20240001 — unique within shop
  deviceType    String
  deviceBrand   String?
  deviceModel   String?
  imei          String?
  accessories   String?
  appearance    String?
  problem       String
  diagnosis     String?
  solution      String?
  estimatedCost Float     @default(0)
  finalCost     Float     @default(0)
  deposit       Float     @default(0)
  paid          Float     @default(0)
  warranty      Int       @default(0)
  paymentMethod String?
  status        String    @default("received")
  receivedAt    DateTime  @default(now())
  promisedAt    DateTime?
  completedAt   DateTime?
  deliveredAt   DateTime?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

  items   ServiceItem[]
  history ServiceStatusHistory[]

  @@unique([shopId, code])
  @@index([shopId, status])
}

model ServiceItem {
  id          String @id @default(cuid())
  description String
  quantity    Int    @default(1)
  unitPrice   Float
  subtotal    Float

  ticketId String
  ticket   ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])
}

model ServiceStatusHistory {
  id        String   @id @default(cuid())
  status    String
  note      String?
  createdAt DateTime @default(now())

  ticketId String
  ticket   ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}
